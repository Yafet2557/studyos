// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// enums
enum Status {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum EntityType {
  ASSIGNMENT
  NOTE
}

enum OutputType {
  SUBTASKS
  SUMMARY
  QUESTIONS
  PLAN
}

enum CardSource {
  NOTE
  ASSIGNMENT
  MANUAL
}

enum SessionType {
  REVIEW
  LEARN
  CRAM
}

// models
model User {
  id          String       @id @default(cuid())
  email       String       @unique
  password    String
  createdAt   DateTime     @default(now())
  courses       Course[]
  assignments   Assignment[]
  subtasks      Subtask[]
  notes         Note[]
  aiOutputs     AiOutput[]
  studyCards    StudyCard[]
  studySessions StudySession[]
  focusSessions FocusSession[]
}

model Course {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  code        String?
  color       String?
  isActive    Boolean      @default(true)
  assignments   Assignment[]
  notes         Note[]
  studyCards    StudyCard[]
  studySessions StudySession[]
  focusSessions FocusSession[]
}

model Assignment {
  id             String     @id @default(cuid())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId       String?
  course         Course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  dueDate        DateTime?
  status         Status     @default(TODO)
  priority       Priority   @default(MEDIUM)
  estimatedHours Decimal?   @db.Decimal(4, 1)
  subtasks       Subtask[]
  notes          Note[]
  aiOutputs      AiOutput[]
  focusSessions  FocusSession[]
}

model Subtask {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  isDone       Boolean    @default(false)
  position     Int        @default(0)
}

model Note {
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  courseId     String?
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  title        String
  content      String      @default("")
  aiOutputs    AiOutput[]
  studyCards   StudyCard[]
}

model AiOutput {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType   EntityType
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  noteId       String?
  note         Note?       @relation(fields: [noteId], references: [id], onDelete: Cascade)
  outputType   OutputType
  content      Json
  modelUsed    String
}

model StudyCard {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId      String?
  course        Course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)
  noteId       String?
  note         Note?       @relation(fields: [noteId], references: [id], onDelete: SetNull)
  front        String
  back         String
  source       CardSource  @default(MANUAL)

  // SM-2 spaced repetition fields
  easeFactor   Float       @default(2.5)
  interval     Int         @default(0)        // days until next review
  repetitions  Int         @default(0)        // consecutive correct answers
  nextReviewAt DateTime    @default(now())
  lastReviewAt DateTime?

  reviews      StudyCardReview[]

  @@index([userId, nextReviewAt])
  @@index([userId, courseId])
}

model StudyCardReview {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  studyCardId  String
  studyCard    StudyCard   @relation(fields: [studyCardId], references: [id], onDelete: Cascade)
  sessionId    String
  session      StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  quality      Int         // SM-2 quality rating: 0-5
  easeFactor   Float       // snapshot of easeFactor after this review
  interval     Int         // snapshot of interval after this review
}

model StudySession {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId      String?
  course        Course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)
  type         SessionType @default(REVIEW)
  cardsStudied Int         @default(0)
  correctCount Int         @default(0)
  durationSecs Int?        // null if session is still in progress
  completedAt  DateTime?

  reviews      StudyCardReview[]

  @@index([userId, createdAt])
}

model FocusSession {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     String?
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  durationMins Int
  actualSecs   Int?
  completedAt  DateTime?
  label        String?

  @@index([userId, createdAt])
}
